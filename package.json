{
  "name": "perchance-ai-prompt-library",
  "version": "8.0.0",
  "description": "Perchance.ai toolkit — AI-powered .perchance generator builder with MCP server, Playwright automation, OpenClaw skill, and 150+ templates",
  "type": "module",
  "bin": {
    "perchance-gen": "./dist/cli/index.js",
    "perchance-mcp": "./dist/mcp/server.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/types/perchance.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/cli/index.ts",
    "mcp": "tsx src/mcp/server.ts",
    "mcp:build": "tsc && node dist/mcp/server.js",
    "lint": "eslint src --ext .ts",
    "test": "jest"
  },
  "keywords": [
    "perchance",
    "perchance-ai",
    "generator",
    "prompt-generator",
    "ai-tools",
    "mcp",
    "mcp-server",
    "playwright",
    "openclaw",
    "cli",
    "text-generation",
    "creative-writing"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "commander": "^12.0.0",
    "groq-sdk": "^0.7.0",
    "zod": "^3.22.0"
  },
  "optionalDependencies": {
    "clipboardy": "^4.0.0",
    "playwright": "^1.45.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "jest": "^29.0.0",
    "@types/jest": "^29.0.0",
    "eslint": "^8.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "author": "Gzeu",
  "homepage": "https://github.com/Gzeu/perchance-ai-prompt-library",
  "repository": {
    "type": "git",
    "url": "https://github.com/Gzeu/perchance-ai-prompt-library.git"
  }
}
